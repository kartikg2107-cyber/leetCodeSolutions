class Solution {
    public int maximumGap(int[] nums) {
        if(nums.length==1){
            return 0;
        } 
        int max=Integer.MIN_VALUE;
        int diff=0;
        Arrays.sort(nums);
        for(int  i=0;i<nums.length-1;i++){
            diff=nums[i+1]-nums[i];
            max= Math.max(max,diff);
        }
        return max;
    }
}
