class Solution {
    public boolean containsDuplicate(int[] nums) {
       int low =0;
       int high = nums.length-1;
       while(low<high){
        for(int i=low+1;i<nums.length;i++){
            if(nums[low]==nums[i]){
               return true;
            }
        }
        low++;
    }
      return false;
    }
}
