class Solution {
    public int climbStairs(int n) {
        int a=1;
        int b=2;
        int temp=0;
        if(n==1){
            return a;
        }
          else if(n==2){
            return b;
           }     else {
        for(int i=3;i<=n;i++){
            temp=a+b;
            a=b;
            b=temp;
            }
        }
        return temp;
    }
}
